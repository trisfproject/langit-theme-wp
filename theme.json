{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "1180px",
			"wideSize": "1320px"
		},
		"color": {
			"custom": true,
			"palette": [
				{
					"name": "Primary",
					"slug": "primary",
					"color": "#58AFFF"
				},
				{
					"name": "Secondary",
					"slug": "secondary",
					"color": "#0F172A"
				},
				{
					"name": "Accent",
					"slug": "accent",
					"color": "#38BDF8"
				},
				{
					"name": "Background",
					"slug": "background",
					"color": "#F8FAFC"
				},
				{
					"name": "Text",
					"slug": "text",
					"color": "#0B1120"
				}
			]
		},
		"spacing": {
			"spacingScale": {
				"steps": 0
			},
			"spacingSizes": [
				{
					"name": "Small",
					"slug": "small",
					"size": "clamp(0.75rem, 0.65rem + 0.5vw, 1rem)"
				},
				{
					"name": "Medium",
					"slug": "medium",
					"size": "clamp(1rem, 0.8rem + 1vw, 1.5rem)"
				},
				{
					"name": "Large",
					"slug": "large",
					"size": "clamp(1.5rem, 1.1rem + 2vw, 2.75rem)"
				},
				{
					"name": "Extra Large",
					"slug": "x-large",
					"size": "clamp(2.5rem, 1.75rem + 3.75vw, 5rem)"
				}
			],
			"units": [
				"px",
				"rem",
				"%",
				"vw",
				"vh"
			]
		},
		"typography": {
			"customFontSize": true,
			"fontFamilies": [
				{
					"name": "Modern Sans",
					"slug": "modern-sans",
					"fontFamily": "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif"
				}
			],
			"fontSizes": [
				{
					"name": "Small",
					"slug": "small",
					"size": "0.875rem"
				},
				{
					"name": "Base",
					"slug": "base",
					"size": "1rem"
				},
				{
					"name": "Large",
					"slug": "large",
					"size": "1.25rem"
				},
				{
					"name": "Heading",
					"slug": "heading",
					"size": "clamp(2rem, 1.55rem + 2.25vw, 4rem)"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "#F8FAFC",
			"text": "#0B1120"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--modern-sans)",
			"lineHeight": "1.65"
		},
		"elements": {
			"button": {
				"border": {
					"radius": "8px"
				},
				"color": {
					"background": "#58AFFF",
					"text": "#0F172A"
				},
				"typography": {
					"fontWeight": "750"
				}
			},
			"heading": {
				"color": {
					"text": "#0F172A"
				},
				"typography": {
					"fontWeight": "750",
					"lineHeight": "1.12"
				}
			},
			"link": {
				"color": {
					"text": "#0F172A"
				}
			}
		}
	}
}
